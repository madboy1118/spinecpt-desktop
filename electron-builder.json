{
  "appId": "com.spinecpt.pro",
  "productName": "SpineCPT Pro",
  "copyright": "Copyright (c) 2026 University of Maryland. All rights reserved.",
  "publish": {
    "provider": "github",
    "owner": "spinecpt",
    "repo": "spinecpt-desktop",
    "releaseType": "release"
  },
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "main.js",
    "preload.js",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "vendor/whispercpp",
      "to": "whispercpp",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.png",
    "signAndEditExecutable": false
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.png",
    "category": "public.app-category.medical"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
